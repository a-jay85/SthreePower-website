<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!--
      Belt-and-suspenders: refuse to serve the secret file even if it lives in the webroot.
      PHP normally executes .php (so source is never exposed), but this denies it outright.
    -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="config.local.php" />
          <add segment="config.local.php.example" />
        </hiddenSegments>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
