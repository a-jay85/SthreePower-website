# Provide these to config.php one of two ways:
#   A) RECOMMENDED on Plesk/Windows-IIS — create `config.local.php` ONE LEVEL ABOVE the
#      document root (so it's never web-served), returning an array:
#          <?php return [
#            'GOOGLE_CLIENT_ID' => '...', 'GOOGLE_CLIENT_SECRET' => '...',
#            'GOOGLE_REDIRECT_URI' => 'https://sthreepower.org/google-callback.php',
#            'SHEET_WEBHOOK_URL' => '...', 'SHEET_SHARED_SECRET' => '...',
#          ];
#   B) OR set real OS environment variables (only if the host exposes them to getenv()).
# Do NOT put real values in a committed file — .gitignore ignores .env.* but not .env.example.

# Google OAuth 2.0 client (Google Cloud Console → APIs & Services → Credentials →
# OAuth client ID → "Web application").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://sthreepower.org/google-callback.php

# Google Sheet capture webhook (Apps Script web-app deployment URL) + a shared secret
# that the Apps Script doPost() must check before appending a row.
SHEET_WEBHOOK_URL=
SHEET_SHARED_SECRET=

# Signing key for the email double-opt-in confirmation links (HMAC-SHA256). Any long
# random string; keep it secret and stable. Generate: php -r "echo bin2hex(random_bytes(32));"
CONFIRM_SECRET=
